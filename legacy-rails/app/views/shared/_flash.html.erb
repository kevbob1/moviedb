<% if flash[:notice].present? || flash[:alert].present? %>
  <div class="fixed top-4 right-4 z-50 flex flex-col gap-2">
    <% if flash[:notice].present? %>
      <div data-controller="toast" data-toast-duration-value="5000"
           class="bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 rounded-lg shadow-lg px-4 py-3 flex items-center gap-3 max-w-sm">
        <span><%= flash[:notice] %></span>
        <button type="button" data-action="click->toast#dismiss" class="ml-auto text-green-600 dark:text-green-300 hover:opacity-70">&times;</button>
      </div>
    <% end %>
    <% if flash[:alert].present? %>
      <div data-controller="toast" data-toast-duration-value="8000"
           class="bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200 rounded-lg shadow-lg px-4 py-3 flex items-center gap-3 max-w-sm">
        <span><%= flash[:alert] %></span>
        <button type="button" data-action="click->toast#dismiss" class="ml-auto text-red-600 dark:text-red-300 hover:opacity-70">&times;</button>
      </div>
    <% end %>
  </div>
<% end %>
