<% content_for :title, "Movies" %>

<h1 class="text-3xl font-bold mb-6 text-gray-900 dark:text-white">Movies</h1>

<%= form_with url: movies_path, method: :get,
    data: { turbo_frame: "movies_results", controller: "movie-search" } do |f| %>
  <%= f.text_field :q,
      value: params[:q],
      placeholder: "Search movies...",
      class: "w-full md:w-96 px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:outline-none",
      data: { movie_search_target: "input", action: "input->movie-search#search" } %>
<% end %>

<%= render "movies_list" %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mt-8">
  <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Sync from TMDB</h2>
  <%= form_with url: sync_from_tmdb_movies_path, method: :post, local: true, class: "flex flex-col sm:flex-row gap-3 items-start sm:items-end" do |f| %>
    <div class="flex-grow">
      <%= f.label :tmdb_id, "TMDB ID", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.number_field :tmdb_id, required: true, min: 1, placeholder: "Enter TMDB movie ID", class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
    </div>
    <div>
      <%= f.submit "Sync from TMDB", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
