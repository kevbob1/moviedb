{
  "name": "moviedb",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:db": "npx dotenv -e .env.test -- prisma migrate deploy && jest",
    "postinstall": "prisma generate",
    "db:generate:migration": "prisma migrate dev --create-only",
    "db:migrate:dev": "prisma migrate dev",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "check": "npm run db:generate-client && npm run lint && npm run test && npm run typecheck && NEXT_TELEMETRY_DISABLED=1 NODE_ENV=production npm run build",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:test": "npx dotenv -e .env.test -- prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:generate-client": "prisma generate",
    "test:e2e": "npx dotenv -e .env.test -- prisma migrate reset --force && npx dotenv -e .env.test -- prisma migrate deploy && npx dotenv -e .env.test -- tsx tests/seed.ts && npx dotenv -e .env.test -- next dev -p 3000 & SERVER_PID=$! && npx wait-on http://localhost:3000 && npx playwright test; kill $SERVER_PID 2>/dev/null"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevbob1/moviedb.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "homepage": "https://github.com/kevbob1/moviedb#readme",
  "type": "module",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.4",
    "prisma": "^7.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "glob": "^13.0.0",
    "postcss": "^8.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  }
}
