<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 max-w-2xl">
  <%= form_with(model: movie) do |form| %>
    <% if movie.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
        <h2 class="text-red-800 dark:text-red-400 font-medium mb-2"><%= pluralize(movie.errors.count, "error") %> prohibited this movie from being saved:</h2>
        <ul class="list-disc list-inside text-red-700 dark:text-red-300 text-sm space-y-1">
          <% movie.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if movie.tmdb_id.present? %>
      <div class="mb-4 text-sm text-gray-500 dark:text-gray-400">
        TMDB ID: <%= movie.tmdb_id %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none" %>
    </div>

    <div class="mb-4">
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.text_area :description, rows: 5, class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none" %>
    </div>

    <div class="mb-4">
      <%= form.label :release_date, "Release Year", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.number_field :release_date, class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:outline-none" %>
    </div>

    <div class="mt-6">
      <%= form.submit class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
