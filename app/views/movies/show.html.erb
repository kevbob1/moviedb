<% content_for :title, @movie.title %>

<div class="flex flex-col md:flex-row gap-8">
  <div class="flex-shrink-0">
    <% if @movie.poster_path.present? %>
      <%= image_tag "https://image.tmdb.org/t/p/w342#{@movie.poster_path}", alt: @movie.title, class: "rounded-lg shadow-lg w-full max-w-xs mx-auto md:mx-0", loading: "lazy" %>
    <% else %>
      <div class="w-full max-w-xs h-96 bg-gray-200 dark:bg-gray-700 rounded-lg flex items-center justify-center text-gray-400">No Poster</div>
    <% end %>
  </div>

  <div class="flex-grow">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2"><%= @movie.title %></h1>

    <div class="flex items-center gap-3 mb-4 flex-wrap">
      <% if @movie.vote_average.present? && @movie.vote_average > 0 %>
        <span class="inline-flex items-center px-2.5 py-1 rounded text-sm font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200"><%= "★ #{format('%.1f', @movie.vote_average)}" %></span>
      <% end %>

      <% if @movie.release_date.present? %>
        <span class="text-sm text-gray-500 dark:text-gray-400"><%= @movie.release_date %></span>
      <% end %>
    </div>

    <% if @movie.genres.present? %>
      <div class="flex flex-wrap gap-2 mb-4">
        <% @movie.genres.split(",").map(&:strip).each do |genre| %>
          <span class="px-3 py-1 rounded-full text-sm bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300"><%= genre %></span>
        <% end %>
      </div>
    <% end %>

    <% if @movie.description.present? %>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6"><%= @movie.description %></p>
    <% end %>

    <div class="flex items-center gap-3 mt-6">
      <%= link_to "Edit", edit_movie_path(@movie), class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors" %>
      <%= link_to "Back to movies", movies_path, class: "px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg text-sm font-medium transition-colors" %>
      <%= button_to "Delete", @movie, method: :delete, class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to delete this movie?" } } %>
    </div>
  </div>
</div>
