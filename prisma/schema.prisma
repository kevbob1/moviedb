datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// status: pending | downloading | fulfilled | canceled (see RequestStatus in src/lib/request-fsm.ts)
model Request {
  id            Int      @id @default(autoincrement())
  title         String
  tmdb_id       Int?
  season_number Int?
  poster_path   String?
  release_date  String?  // year or yyyy-mm-dd; not a precise moment
  overview      String?
  genre_ids     Int[]    @default([])
  requested_at  DateTime @default(now())
  requested_by  String   // opaque identifier; no User relation
  status        String   @default("pending")
  media_type    String   @default("movie") // movie | tv

  @@map("requests")
}

// status: pending | processing | completed | failed
// type:   open set registered via registerJobType(); known values:
//   - request_notification
//   - tv_series_request_notification
model Job {
  id           Int       @id @default(autoincrement())
  type         String
  payload      Json      @db.JsonB
  status       String    @default("pending")
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  error        String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  completed_at DateTime?

  @@index([status])
  @@index([status, created_at])
  @@map("jobs")
}
