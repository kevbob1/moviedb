datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Movie {
  id           String   @id @default(uuid())
  tmdb_id      Int      @unique
  title        String
  release_date Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}