{
  "name": "moviedb",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "25.9.0"
    }
  },
  "postCreateCommand": "npm install && npx prisma generate",
  "forwardPorts": [3000, 5432, 9092],
  "containerEnv": {
    "DATABASE_HOST": "db",
    "DATABASE_PASSWORD": "new_password",
    "DATABASE_URL": "postgresql://moviedb:new_password@db:5432/moviedb?schema=public",
    "KAFKA_BROKERS": "kafka:9092",
    "KAFKA_USERNAME": "moviedb",
    "KAFKA_PASSWORD": "moviedb-secret"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "prisma.prisma"
      ]
    }
  }
}
