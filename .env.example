DATABASE_URL="postgresql://postgres:postgres@postgres:5432/moviedb_development"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PORT=3000
# HOST_PORT is the host-side port mapped to the web container's port 3000.
# Defaults to PORT when unset. Override here (or in .env.local) if 3000 is in use
# on the host (e.g. another dev stack).
# HOST_PORT=3000
